# Copy this file to .env and fill in your values
# This file is gitignored — never commit .env

# Your Firebase configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here

# Your Gemini API key (same as GitHub Secret GEMINI_API_KEY)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Your Firebase UID — leave blank until you sign in once and get it from the browser console
VITE_ALLOWED_UID=
